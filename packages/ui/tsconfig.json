{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler", // ou "node" dependendo da sua versão
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@easygoal/packages/auth/client": ["../auth/src/index.ts"],
      "@easygoal/packages/auth/server": ["../auth/src/server.ts"]
    },
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}